# Example frontend/.env.example
# Copy this file to frontend/.env and update the `VITE_API_URL` value for your local backend.

VITE_API_URL=http://localhost:3001

# If your backend runs on a different port, adjust accordingly, e.g.:
# VITE_API_URL=http://localhost:4000

# Notes:
# - Vite environment variables used in the client must be prefixed with `VITE_`.
# - After editing `frontend/.env`, restart the dev server: `cd frontend && npm run dev`.
