# backend/.env.example
# Copy this to backend/.env and fill the values (do NOT commit .env)

# Option A: Single connection string
# DATABASE_URL=postgres://blocknote:YourPassword@localhost:5432/blocknote_dev

# Option B: Individual fields (use these if you prefer SQLTools or explicit config)
DB_USER=blocknote
DB_PASSWORD=YourPassword
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blocknote_dev

# JWT secret used by auth routes
JWT_SECRET=replace_with_a_long_random_string

# App config
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# If you store an encrypted env file (backend/.env.enc), decrypt it to backend/.env
# Example using openssl (AES-256-CBC):
# openssl enc -d -aes-256-cbc -in backend/.env.enc -out backend/.env
# Then restart the server so dotenv loads backend/.env
